{
  "name": "@ai4s/codex-bridge",
  "version": "0.1.9",
  "private": true,
  "type": "module",
  "description": "OpenCode-compatible HTTP+SSE bridge that runs the agent on the OpenAI Codex SDK. Accepts the same CLI/env contract as `opencode serve`, so the desktop shell and the web server can spawn it as a drop-in sidecar.",
  "bin": {
    "codex-bridge": "./src/server.mjs"
  },
  "files": [
    "src/server.mjs",
    "src/claude-agent.mjs",
    "src/claude-agent-mcp.mjs",
    "src/codex-client-config.mjs",
    "src/inline-citations.mjs",
    "src/main-agent-prompt.mjs",
    "src/prompts",
    "src/science-execution.mjs",
    "src/execution-result.mjs",
    "src/science-job-worker.mjs",
    "src/science-mcp.mjs",
    "src/research-mcp.mjs",
    "src/research-result.mjs",
    "src/research-routing.mjs",
    "src/web-research.mjs",
    "src/workers",
    "src/extensions.mjs",
    "src/reviewer.mjs",
    "src/subagents.mjs"
  ],
  "scripts": {
    "start": "node src/server.mjs serve --hostname 127.0.0.1 --port 4096",
    "test": "node --test --test-concurrency=1 src/*.test.mjs"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.210",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@openai/codex-sdk": "^0.144.1",
    "zod": "^4.4.3"
  }
}
